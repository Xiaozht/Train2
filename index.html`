<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Art of Trains | A Journey for Kids</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --apple-bg: #ffffff;
            --apple-text: #1d1d1f;
            --apple-subtext: #86868b;
            --accent: #0066cc;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--apple-bg);
            color: var(--apple-text);
            overflow-x: hidden;
        }

        #progress {
            position: fixed;
            top: 0;
            left: 0;
            width: 0%;
            height: 4px;
            background: var(--accent);
            z-index: 1000;
        }

        nav {
            position: fixed;
            top: 0;
            width: 100%;
            height: 44px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            z-index: 999;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid #d2d2d7;
        }

        nav span {
            font-size: 12px;
            font-weight: 400;
            color: var(--apple-text);
            opacity: 0.8;
        }

        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 800;
            letter-spacing: -0.02em;
            margin: 0;
            line-height: 1.1;
        }

        .hero p {
            font-size: clamp(1.2rem, 3vw, 2rem);
            color: var(--apple-subtext);
            max-width: 700px;
            margin: 20px auto;
            font-weight: 400;
        }

        /* --- NEW 3D SECTION STYLE --- */
        .model-section {
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: #f5f5f7;
            position: relative;
            padding: 40px 20px;
            box-sizing: border-box;
        }

        .model-header {
            text-align: center;
            margin-bottom: 30px;
            z-index: 10;
        }

        .model-header h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 800;
            margin: 0;
        }

        .model-header p {
            color: var(--apple-subtext);
            font-size: 1.2rem;
        }

        #canvas-container {
            width: 100%;
            height: 70vh;
            cursor: grab;
            background: transparent;
            border-radius: 30px;
            position: relative;
        }

        #canvas-container:active {
            cursor: grabbing;
        }

        .model-hint {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.9rem;
            color: var(--apple-subtext);
            pointer-events: none;
        }

        /* --- END 3D SECTION STYLE --- */

        .gallery {
            padding-bottom: 10vh;
        }

        .train-section {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            padding: 40px;
            box-sizing: border-box;
        }

        .content-box {
            max-width: 600px;
            opacity: 0;
            transform: translateY(50px);
            text-align: center;
        }

        h1 {
            font-size: 4rem;
            font-weight: 900;
            margin-bottom: 1rem;
            letter-spacing: -2px;
        }

        p {
            font-size: 1.5rem;
            line-height: 1.4;
            color: #86868b;
        }

        footer {
            padding: 100px 20px;
            background: #f5f5f7;
            text-align: center;
            font-size: 1.2rem;
            color: var(--apple-subtext);
        }

        @media (max-width: 900px) {
            .model-section { height: auto; padding: 80px 20px; }
            #canvas-container { height: 50vh; }
        }
    </style>
</head>
<body>

    <div id="progress"></div>
    <nav><span>Experience The Rail Journey</span></nav>

    <section class="hero">
        <h1>Powerful. <br>Majestic. <br>Trains.</h1>
        <p>An exploration of the engineering marvels that move our world.</p>
    </section>

    <!-- NEW: 3D Interactive Section -->
    <section class="model-section" id="three-d-section">
        <div class="model-header">
            <h2>Explore in 3D</h2>
            <p>Drag to rotate • Scroll to zoom</p>
        </div>
        <div id="canvas-container">
            <div class="model-hint">Interact with the train model below</div>
        </div>
    </section>

    <div class="gallery">
        <!-- Original scrollytelling sections -->
        <section class="train-section">
            <div class="content-box" id="text-1">
                <h1>The Steam Era</h1>
                <p>Where it all began. The rhythmic chugging of steam engines changed how humans traveled forever.</p>
            </div>
        </section>

        <section class="train-section">
            <div class="content-box" id="text-2">
                <h1>Diesel Power</h1>
                <p>Efficient and strong. Diesel trains brought reliability and speed to long-distance hauling.</p>
            </div>
        </section>

        <section class="train-section">
            <div class="content-box" id="text-3">
                <h1>Electric Grace</h1>
                <p>Clean, quiet, and incredibly fast. Electric rails power the modern cities of today.</p>
            </div>
        </section>

        <section class="train-section">
            <div class="content-box" id="text-4">
                <h1>Bullet Speed</h1>
                <p>Cutting through the air with precision. Shinkansen-style trains redefine the meaning of travel.</p>
            </div>
        </section>

        <section class="train-section">
            <div class="content-box" id="text-5">
                <h1>Future Rails</h1>
                <p>Floating on magnets and gliding through vacuum tubes. The next frontier is here.</p>
            </div>
        </section>
    </div>

    <footer>
        <p>© 2026 Train Explorers. Built with elegance for curious minds.</p>
    </footer>

    <!-- THREE.JS LOADERS -->
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build-three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        const container = document.getElementById('canvas-container');
        const width = container.clientWidth;
        const height = container.clientHeight;

        // Scene Setup
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0xf5f5f7);

        const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
        camera.position.set(3, 2, 5);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(width, height);
        renderer.setPixelRatio(window.devicePixelRatio);
        renderer.toneMapping = THREE.ACESFilmicToneMapping;
        renderer.shadowMap.enabled = true;
        container.appendChild(renderer.domElement);

        // Lighting
        const ambientLight = new THREE.AmbientLight(0xffffff, 1.5);
        scene.add(ambientLight);

        const dirLight = new THREE.DirectionalLight(0xffffff, 2);
        dirLight.position.set(5, 10, 7.5);
        dirLight.castShadow = true;
        scene.add(dirLight);

        // Controls
        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;

        // Load Model
        const loader = new GLTFLoader();
        loader.load('Train_3D.glb', (gltf) => {
            const model = gltf.scene;

            // Center the model
            const box = new THREE.Box3().setFromObject(model);
            const center = box.getCenter(new THREE.Vector3());
            model.position.x += (model.position.x - center.x);
            model.position.y += (model.position.y - center.y);
            model.position.z += (model.position.z - center.z);

            scene.add(model);
        }, undefined, (error) => {
            console.error('Error loading model:', error);
        });

        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            const w = container.clientWidth;
            const h = container.clientHeight;
            camera.aspect = w / h;
            camera.updateProjectionMatrix();
            renderer.setSize(w, h);
        });

        animate();
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script>
        gsap.registerPlugin(ScrollTrigger);

        window.onscroll = function() {
            let winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            let height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            let scrolled = (winScroll / height) * 100;
            document.getElementById("progress-bar")?.style.setProperty('width', scrolled + "%");
        };

        // Text animations from original project
        const texts = ['#text-1', '#text-2', '#text-3', '#text-4', '#text-5'];
        texts.forEach((id, i) => {
            gsap.to(id, {
                scrollTrigger: {
                    trigger: id,
                    start: "top center",
                    end: "bottom center",
                    toggleActions: "play reverse play reverse",
                },
                opacity: 1,
                y: 0,
                duration: 0.8,
                ease: "power2.out"
            });
        });
    </script>
</body>
</html>
